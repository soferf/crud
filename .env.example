# ──────────────────────────────────────────────────────────────────────────────
# Configuración de correo electrónico (SMTP)
# Copia este archivo como .env y completa tus credenciales
# ──────────────────────────────────────────────────────────────────────────────

# Servidor SMTP
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_TIMEOUT=20
AUTH_SEND_LOGIN_ALERT=true

# Tu correo y contraseña de APLICACIÓN
# Gmail: activa la verificación en 2 pasos y luego genera una
# "Contraseña de aplicación" en: myaccount.google.com/apppasswords
MAIL_USERNAME=tu_correo@gmail.com
MAIL_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Nombre visible en el remitente
MAIL_FROM_NAME=Contabilidad Arroceras

# URL base de la aplicación (para los enlaces del correo)
APP_URL=http://localhost:5000

# ──────────────────────────────────────────────────────────────────────────────
# Configuración de IA — Asistente Ollama para onboarding de lotes
# ──────────────────────────────────────────────────────────────────────────────
#
# REQUISITOS:
#   1. Instala Ollama desde: https://ollama.com/download
#   2. Descarga el modelo:   ollama pull qwen2.5:7b-instruct
#   3. Levanta el servicio:  ollama serve   (queda en http://localhost:11434)
#   4. Reinicia la app:      python app.py
#
# Si Ollama no está disponible, la app muestra el formulario manual automáticamente.
# ──────────────────────────────────────────────────────────────────────────────

AI_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_TIMEOUT=30

# Para deshabilitar la IA completamente (siempre formulario manual):
# AI_ENABLED=false

# Configuración recomendada para Gmail:
# - TLS: MAIL_PORT=587, MAIL_USE_TLS=true, MAIL_USE_SSL=false
# - SSL: MAIL_PORT=465, MAIL_USE_TLS=false, MAIL_USE_SSL=true
