# ──────────────────────────────────────────────────────────────────────────────
# Configuración de correo electrónico (SMTP)
# Copia este archivo como .env y completa tus credenciales
# ──────────────────────────────────────────────────────────────────────────────

# Servidor SMTP
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true

# Tu correo y contraseña de APLICACIÓN
# Gmail: activa la verificación en 2 pasos y luego genera una
# "Contraseña de aplicación" en: myaccount.google.com/apppasswords
MAIL_USERNAME=tu_correo@gmail.com
MAIL_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Nombre visible en el remitente
MAIL_FROM_NAME=Contabilidad Arroceras

# URL base de la aplicación (para los enlaces del correo)
APP_URL=http://localhost:5000
